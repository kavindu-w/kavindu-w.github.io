---
export interface Props {
  imgPath: string;
  title: string;
  p1?: string;
  p2?: string;
  p3?: string;
  p4?: string;
  techStack?: string;
  ghLink?: string;
  demoLink?: string;
  demoButtonName?: string;
  demoLink2?: string;
  demoButtonName2?: string;
}

const { imgPath, title, p1, p2, p3, p4, techStack, ghLink, demoLink, demoButtonName, demoLink2, demoButtonName2 } = Astro.props;
---

<div class="card project-card-view">
  <img src={imgPath} class="card-img-top" alt={title} loading="lazy" />
  <div class="card-body d-flex flex-column">
    <h5 class="card-title">
      <strong class="purple">{title}</strong>
    </h5>
    {p1 && <p class="card-text" style="text-align:justify">{p1}</p>}
    {p2 && <p class="card-text" style="text-align:justify">{p2}</p>}
    {p3 && <p class="card-text" style="text-align:justify">{p3}</p>}
    {p4 && <p class="card-text" style="text-align:justify">{p4}</p>}
    {techStack && (
      <p class="card-text mt-auto" style="text-align:center">
        <strong>Technologies Used:</strong>{" "}
        <strong class="purple">{techStack}</strong>
      </p>
    )}
    <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:0.75rem">
      {ghLink && (
        <a href={ghLink} target="_blank" rel="noreferrer" class="btn btn-primary">
          GitHub
        </a>
      )}
      {demoLink && (
        <a href={demoLink} target="_blank" rel="noreferrer" class="btn btn-primary">
          {demoButtonName ?? "Demo"}
        </a>
      )}
      {demoLink2 && (
        <a href={demoLink2} target="_blank" rel="noreferrer" class="btn btn-primary">
          {demoButtonName2 ?? "Demo 2"}
        </a>
      )}
    </div>
  </div>
</div>
